{
  "entities": {
    "Ticket": {
      "title": "Ticket",
      "description": "An exit ticket generated by a teacher.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the ticket." },
        "subject": { "type": "string", "description": "The subject of the ticket." },
        "topic": { "type": "string", "description": "The topic of the ticket." },
        "cls": { "type": "string", "description": "The class or year group." },
        "status": { "type": "string", "enum": ["active", "draft"], "description": "The status of the ticket." },
        "type": { "type": "string", "enum": ["quiz", "circle", "reflect", "mixed", "upload"], "description": "The type of the ticket." },
        "source": { "type": "string", "enum": ["generated", "manual", "upload", "link"], "description": "The source of the ticket." },
        "html": { "type": "string", "description": "The full HTML content of the ticket." },
        "url": { "type": "string", "description": "Optional external URL for the ticket." },
        "learnerAmbitions": { "type": "array", "items": { "type": "string" }, "description": "Associated learner ambitions." },
        "color": { "type": "string", "description": "A color hex code for branding." },
        "created": { "type": "string", "description": "Date string when the ticket was created." },
        "teacherId": { "type": "string", "description": "The UID of the teacher who created the ticket." },
        "teacherEmail": { "type": "string", "description": "The email of the teacher who created the ticket." },
        "questions": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["mcq", "circle", "reflect"] },
              "text": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correct": { "type": "integer" }
            }
          }
        }
      },
      "required": ["name", "status", "type", "source", "teacherId"]
    },
    "Response": {
      "title": "Response",
      "description": "A student's response to an exit ticket.",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string", "description": "The ID of the ticket being answered." },
        "ticketName": { "type": "string", "description": "The name of the ticket at the time of submission." },
        "studentName": { "type": "string", "description": "The name entered by the student." },
        "yearGroup": { "type": "string", "description": "The year group or class of the student." },
        "answers": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "questionIndex": { "type": "integer" },
              "questionText": { "type": "string" },
              "answer": { "type": "string" },
              "isCorrect": { "type": "boolean" }
            }
          }
        },
        "submittedAt": { "type": "string", "description": "ISO date string of submission." },
        "teacherId": { "type": "string", "description": "The UID of the teacher who owns the ticket." }
      },
      "required": ["ticketId", "studentName", "submittedAt", "teacherId"]
    }
  },
  "firestore": {
    "tickets": {
      "schema": "Ticket",
      "description": "A shared collaborative collection of all exit tickets."
    },
    "responses": {
      "schema": "Response",
      "description": "Student submissions for exit tickets."
    }
  }
}
