rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tickets
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - subject: string (optional)
    //   - topic: string (optional)
    //   - cls: string (optional)
    //   - status: string (enum: ['active', 'draft'])
    //   - type: string (enum: ['quiz', 'circle', 'reflect', 'mixed', 'upload'])
    //   - source: string (enum: ['generated', 'manual', 'upload', 'link'])
    //   - html: string (optional)
    //   - learnerAmbitions: list (strings)
    //   - color: string (optional)
    //   - created: string (optional)
    //   - url: string (optional)
    //   - teacherId: string (required)
    //   - teacherEmail: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidTicket(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.status in ['active', 'draft'] &&
             data.type in ['quiz', 'circle', 'reflect', 'mixed', 'upload'] &&
             data.source in ['generated', 'manual', 'upload', 'link'] &&
             data.teacherId is string &&
             (!('subject' in data) || (data.subject is string && data.subject.size() < 200)) &&
             (!('topic' in data) || (data.topic is string && data.topic.size() < 200)) &&
             (!('cls' in data) || (data.cls is string && data.cls.size() < 100)) &&
             (!('color' in data) || (data.color is string && data.color.size() < 20)) &&
             (!('created' in data) || (data.created is string)) &&
             (!('teacherEmail' in data) || (data.teacherEmail is string && data.teacherEmail.size() < 200)) &&
             (!('html' in data) || (data.html is string && data.html.size() < 1048576)) && // 1MB limit
             (!('url' in data) || (data.url is string && data.url.size() < 2048)) &&
             (!('learnerAmbitions' in data) || (data.learnerAmbitions is list && data.learnerAmbitions.size() < 20)) &&
             (!('questions' in data) || (data.questions is list && data.questions.size() < 50));
    }

    match /tickets/{ticketId} {
      // All authenticated teachers can read all tickets (collaborative library)
      allow read: if isAuthenticated();
      
      // Teachers can create tickets with their own UID
      allow create: if isAuthenticated() && 
                     isValidTicket(request.resource.data) && 
                     request.resource.data.teacherId == request.auth.uid;
      
      // Teachers can update their own tickets
      allow update: if isAuthenticated() && 
                     isValidTicket(request.resource.data) && 
                     resource.data.teacherId == request.auth.uid &&
                     request.resource.data.teacherId == request.auth.uid;
      
      // Teachers can delete their own tickets
      allow delete: if isAuthenticated() && 
                     resource.data.teacherId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
