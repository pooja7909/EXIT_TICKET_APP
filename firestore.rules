rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Shared Collaborative Rules
    // ===============================================================
    
    match /tickets/{ticketId} {
      // Allow public read/write for collaborative use without login
      allow read, write: if true;
    }

    match /responses/{responseId} {
      // Allow students to submit and teachers to view results
      allow read, create: if true;
      // Prevent editing or deleting responses publicly
      allow update, delete: if false;
    }

    match /test/{docId} {
      // Used for connection testing
      allow read: if true;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
